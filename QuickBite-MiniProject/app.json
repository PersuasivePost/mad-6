{
  "expo": {
    "name": "QuickBite",
    "slug": "QuickBite",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "scheme": "quickbite",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#F58220"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.quickbite.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#F58220"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.quickbite.app"
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": false
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "e7f603c0-ff5e-4c12-a09e-b5daf9d0ed12"
      }
    }
  }
}
